---
import ArrowCard from "@components/ArrowCard.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import WorkCard from "@components/WorkCard.astro";
import { HOME, SITE, SOCIALS } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort(
    (a, b) =>
      new Date(b.data.dateStart).valueOf() -
      new Date(a.data.dateStart).valueOf(),
  )
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  }),
);

const skillsData = await getCollection("skills");
const skills = skillsData[0].data.skills ?? [];
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h2 class="animate font-semibold text-black dark:text-white">
      Hello World!
    </h2>
    <div class="space-y-16">
      <!-- Hero section -->
      <section>
        <article class="space-y-4">
          <p class="animate">
            I’m <strong>Jesal</strong>, a <strong>Software Engineer</strong> with
            <strong>2+ years of experience</strong> building production web applications
            using <strong>React</strong>, <strong>Next.js</strong>,
            <strong>TypeScript</strong>, and <strong>Node.js</strong>. I focus
            on
            <strong>scalable frontend architecture</strong>,
            <strong>reusable components</strong>, and
            <strong>performance optimization</strong> to deliver fast and maintainable
            user experiences.
          </p>

          <p class="animate">
            Currently at <a
              href="https://www.concettolabs.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold underline"
            >
              Concetto Labs
            </a>, I’ve worked on products like
            <a
              href="https://jobalots.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold underline"
            >
              Jobalots
            </a>,
            <a
              href="https://elitechem.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold underline"
            >
              EliteChem
            </a>, and
            <a
              href="https://bargainfox.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold underline"
            >
              BargainFox
            </a>, improving <strong>SEO</strong>,
            <strong>performance</strong>, <strong>caching</strong>, and
            <strong>frontend scalability</strong> by contributing to
            <strong>30% faster development</strong>,
            <strong>25% lower memory usage</strong>, and
            <strong>35% better page performance</strong>.
          </p>
        </article>
      </section>

      <!-- Projects -->
      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects"> See all projects </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Skills -->
      <section class="animate space-y-6">
        <h5 class="font-semibold text-black dark:text-white">Skills</h5>
        <ul class="flex flex-wrap gap-2">
          {
            skills.map((skill) => (
              <li
                class="cursor-pointer relative group flex items-center justify-center px-4 py-2 rounded-md border border-black/10 dark:border-white/20 bg-white/70 dark:bg-white/5 
         text-sm font-medium text-black dark:text-white 
         hover:bg-black/10 dark:hover:bg-white/10 
         hover:text-black dark:hover:text-white 
         transition-colors duration-300 ease-in-out shadow-sm"
              >
                {skill}
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Experience -->
      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Work Experience
          </h5>
        </div>
        <ul class="flex flex-col gap-4">
          {
            work.map((entry) => (
              <li>
                <WorkCard entry={entry} />
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Contact -->
      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">Let's Connect</h5>
        <article>
          <p>
            Open to exciting full-time opportunities in frontend and full-stack
            development. If you’re building impactful products and need a
            developer who cares about performance, scalability, and clean UI —
            feel free to reach out.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {
            SOCIALS.map((SOCIAL) => (
              <li class="flex gap-x-2 text-nowrap">
                <Link
                  href={SOCIAL.HREF}
                  external
                  aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
                >
                  {SOCIAL.NAME}
                </Link>
                {"/"}
              </li>
            ))
          }
          <li class="line-clamp-1">
            <Link
              href={`mailto:${SITE.EMAIL}`}
              aria-label={`Email ${SITE.NAME}`}
            >
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
